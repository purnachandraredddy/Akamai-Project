# Application settings
APP_NAME=Rick & Morty API
APP_VERSION=1.0.0
DEBUG=false

# API settings
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# External API settings
RICK_MORTY_API_URL=https://rickandmortyapi.com/api
EXTERNAL_API_TIMEOUT=10
EXTERNAL_API_MAX_RETRIES=3
EXTERNAL_API_BACKOFF_DELAY=1.0

# Database settings
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/rickmorty
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=rickmorty
DATABASE_USER=postgres
DATABASE_PASSWORD=password

# Database connection pool settings
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=3600
DB_POOL_PRE_PING=true
DB_ECHO=false
DB_ECHO_POOL=false

# Redis settings
REDIS_URL=redis://localhost:6379/0
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Cache settings
CACHE_TTL=3600
CACHE_L1_TTL=120
CACHE_L2_TTL=600
CACHE_L1_MAX_SIZE=500
CACHE_L1_MAX_VALUE_SIZE=1048576
CACHE_MAX_SIZE=1000
CACHE_JITTER_PERCENT=10
CACHE_MAX_REFRESH_CONCURRENCY=5

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# Monitoring
ENABLE_METRICS=true
METRICS_PORT=9090
ENABLE_TRACING=true
JAEGER_ENDPOINT=jaeger:14268

# Health check settings
HEALTH_CHECK_TIMEOUT=5

# Admin authentication
ADMIN_API_KEY=your-secure-admin-api-key-here
